# Whoop OAuth credentials — copy this file to .env and fill in your values
# Get Client ID and Secret from https://developer.whoop.com
WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here

# Run scripts/get_token.py once to obtain this
WHOOP_REFRESH_TOKEN=your_refresh_token_here

# Server settings (defaults work fine for Fly.io)
PORT=8080
HOST=0.0.0.0
